{
  "name": "bilitoolkit-plugin-image-downloader",
  "version": "0.0.1",
  "private": false,
  "type": "module",
  "main": "index.html",
  "description": "快速下载视频封面、专栏图片、用户头像、动态和评论表情包",
  "author": "hzhilong",
  "keywords": [
    "BiliToolkit",
    "哔哩工具姬",
    "bilitoolkit-plugin",
    "bilitoolkit-plugin:name:图片下载",
    "bilitoolkit-plugin:type:ui"
  ],
  "files": [
    "dist",
    "!dist/bundle-stats.*"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/hzhilong/bilitoolkit-plugins",
    "directory": "bilitoolkit-plugin-image-downloader"
  },
  "bugs": {
    "url": "https://github.com/hzhilong/bilitoolkit-plugins/issues"
  },
  "homepage": "https://github.com/hzhilong/bilitoolkit-plugins/tree/main/bilitoolkit-plugin-image-downloader#readme",
  "scripts": {
    "删除缓存": "rimraf node_modules/.vite",
    "check": "vue-tsc --build --noEmit && eslint .",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "dev": "rimraf node_modules/.vite && chcp 65001 && vite",
    "dev(cache)": "chcp 65001 && vite",
    "build": "vite build",
    "npm login": "npm login",
    "pnpm publish": "pnpm publish --access public"
  },
  "dependencies": {
    "@ybgnb/bili-api": "workspace:^",
    "@ybgnb/utils": "^0.3.1",
    "bilitoolkit-runtime": "workspace:^",
    "bilitoolkit-types": "workspace:^",
    "bilitoolkit-ui": "workspace:^",
    "element-plus": "^2.13.7",
    "lodash-es": "^4.18.1",
    "pinia": "^3.0.3",
    "vue": "^3.5.34",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.2",
    "@types/node": "^22.16.5",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "eslint": "^9.31.0",
    "eslint-plugin-vue": "~10.3.0",
    "prettier": "3.6.2",
    "rimraf": "^6.0.1",
    "sass": "^1.92.1",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^20.1.0",
    "unplugin-vue-components": "^29.0.0",
    "vite": "^7.3.3",
    "vue-tsc": "^3.0.4"
  }
}
