{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": [
    "./src/env.d.ts",
    "./src/global.d.ts",
    "./src/**/*",
    "./src/**/*.vue",
    "./src/**/*.d.ts",
    "./src/**/*.ts"
  ],
  "exclude": [
    "./node_modules",
    ".yalc",
    "yalc.lock",
    "./src/**/__tests__/*"
  ],
  "compilerOptions": {
    "rootDir": "src",
    "strict": true,
    "allowImportingTsExtensions": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "paths": {
      "@/*": [
        "./src/*"
      ],
    },
    "lib": [
      "DOM",
      "ES2015"
    ]
  }
}
