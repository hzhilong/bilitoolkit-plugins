{
  "name": "bilitoolkit-plugin-backup",
  "version": "0.0.2",
  "private": false,
  "type": "module",
  "main": "index.html",
  "productName": "BiliBackup",
  "productCNName": "哔哩备份姬",
  "description": "一键对B站账号进行数据备份和还原，方便账号数据迁移/快速转生",
  "author": "hzhilong",
  "keywords": [
    "BiliToolkit",
    "哔哩工具姬",
    "bilitoolkit-plugin",
    "bilitoolkit-plugin:name:哔哩备份姬",
    "bilitoolkit-plugin:type:ui"
  ],
  "files": [
    "dist",
    "!dist/bundle-stats.*"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/hzhilong/bilitoolkit-plugin-backup"
  },
  "bugs": {
    "url": "https://github.com/hzhilong/bilitoolkit-plugin-backup/issues"
  },
  "homepage": "https://github.com/hzhilong/bilitoolkit-plugin-backup#readme",
  "scripts": {
    "删除缓存": "rimraf node_modules/.vite",
    "check": "vue-tsc --build --noEmit && eslint .",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "dev": "rimraf node_modules/.vite && chcp 65001 && vite",
    "dev(cache)": "chcp 65001 && vite",
    "build": "vite build",
    "npm login": "npm login",
    "npm publish": "npm publish --access public"
  },
  "dependencies": {
    "@ybgnb/bili-api": "workspace:*",
    "@ybgnb/utils": "^0.2.8",
    "@ybgnb/vite-env": "^0.0.7",
    "axios": "^1.12.1",
    "bilitoolkit-runtime": "workspace:*",
    "bilitoolkit-types": "workspace:*",
    "bilitoolkit-ui": "workspace:*",
    "consola": "^3.4.2",
    "dayjs": "^1.11.18",
    "dexie": "^4.2.0",
    "element-plus": "^2.13.7",
    "lodash-es": "^4.18.1",
    "mitt": "^3.0.1",
    "pinia": "^3.0.3",
    "pinia-plugin-persistedstate": "^4.5.0",
    "remixicon": "^4.6.0",
    "vue": "^3.5.34",
    "vue-component-type-helpers": "^3.2.9",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.2",
    "@types/node": "^22.16.5",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitejs/plugin-vue-jsx": "^5.0.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "eslint": "^9.31.0",
    "eslint-plugin-vue": "~10.3.0",
    "madge": "^8.0.0",
    "prettier": "3.6.2",
    "rimraf": "^6.0.1",
    "rollup-plugin-bundle-stats": "^4.21.3",
    "sass": "^1.92.1",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^20.1.0",
    "unplugin-vue-components": "^29.0.0",
    "vite": "^7.3.3",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vue-tsc": "^3.0.4"
  }
}
